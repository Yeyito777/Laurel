server {
    listen 80;
    server_name clips.yeyito.dev;

    root /srv/clips;
    index index.html;

    # Serve clip directories (each has index.html + clip.mp4 + thumb.jpg)
    location / {
        try_files $uri $uri/ $uri/index.html =404;
    }

    # Video files: cache-friendly headers
    location ~* \.(mp4|webm|mkv)$ {
        add_header Accept-Ranges bytes;
        add_header Cache-Control "public, max-age=31536000, immutable";
    }

    # Thumbnails
    location ~* \.(jpg|png)$ {
        add_header Cache-Control "public, max-age=31536000, immutable";
    }

    # Deny hidden files
    location ~ /\. {
        deny all;
    }
}
