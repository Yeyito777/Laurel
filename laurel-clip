#!/bin/sh
# laurel-clip — post-save hook for gpu-screen-recorder
# Called with: laurel-clip <filepath> <type>
# type is "regular", "replay", or "screenshot"

CLIP_FILE="$1"
CLIP_TYPE="$2"

[ -z "$CLIP_FILE" ] && exit 1

# Config resolution: env var → user config → system config
_conf_dir="${XDG_CONFIG_HOME:-${HOME}/.config}/laurel"
_config="${LAUREL_CONFIG:-}"
[ -z "$_config" ] && [ -f "${_conf_dir}/config.sh" ] && _config="${_conf_dir}/config.sh"
[ -z "$_config" ] && [ -f "/etc/laurel/config.sh" ] && _config="/etc/laurel/config.sh"
[ -n "$_config" ] && . "$_config"

# Logging
LAUREL_STATE="${XDG_STATE_HOME:-${HOME}/.local/state}/laurel"
mkdir -p "$LAUREL_STATE"
LAUREL_LOG="${LAUREL_STATE}/laurel.log"
log() { printf '[%s] clip: %s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$1" >> "$LAUREL_LOG"; }

PPID_CMD=""
[ -f "/proc/$PPID/cmdline" ] && PPID_CMD="$(tr '\0' ' ' < /proc/$PPID/cmdline)"
log "triggered file=$CLIP_FILE type=$CLIP_TYPE ppid=$PPID ppid_cmd='${PPID_CMD}'"

# Defaults
CLIP_SERVER="${CLIP_SERVER:-}"
CLIP_DIR="${CLIP_DIR:-/srv/clips}"
CLIP_DOMAIN="${CLIP_DOMAIN:-}"
NOTIFY_CMD="${NOTIFY_CMD:-notify-send}"

# Validate required settings
if [ -z "$CLIP_SERVER" ] || [ -z "$CLIP_DOMAIN" ]; then
    log "ERROR: CLIP_SERVER and CLIP_DOMAIN must be set in config"
    ${NOTIFY_CMD} "Laurel error" "CLIP_SERVER and CLIP_DOMAIN not configured" 2>/dev/null
    exit 1
fi

# Template resolution: user config → system share
CLIP_TEMPLATE=""
[ -f "${_conf_dir}/clip-template.html" ] && CLIP_TEMPLATE="${_conf_dir}/clip-template.html"
[ -z "$CLIP_TEMPLATE" ] && CLIP_TEMPLATE="/usr/share/laurel/clip-template.html"

# Clip sound resolution: user config → system share
CLIP_SOUND=""
[ -f "${_conf_dir}/clip.mp3" ] && CLIP_SOUND="${_conf_dir}/clip.mp3"
[ -z "$CLIP_SOUND" ] && [ -f "/usr/share/laurel/clip.mp3" ] && CLIP_SOUND="/usr/share/laurel/clip.mp3"

# Ident token — generate lazily on first clip save
IDENT_FILE="${_conf_dir}/ident"
if [ ! -f "$IDENT_FILE" ]; then
    mkdir -p "$_conf_dir"
    od -An -tx1 -N16 /dev/urandom | tr -d ' \n' > "$IDENT_FILE"
    log "generated new ident: $(cat "$IDENT_FILE")"
fi
IDENT="$(cat "$IDENT_FILE")"

# Play clip sound (async so it doesn't block upload)
[ -n "$CLIP_SOUND" ] && pw-play "$CLIP_SOUND" &

# Generate unique slug
SLUG="$(date +%Y%m%d-%H%M%S)-$(od -An -tx1 -N4 /dev/urandom | tr -d ' \n')"
FILENAME="$(basename "$CLIP_FILE")"
URL="https://${CLIP_DOMAIN}/${SLUG}"

# Generate HTML page from template
TMPHTML="$(mktemp)"
sed -e "s|{{SLUG}}|${SLUG}|g" \
    -e "s|{{FILENAME}}|${FILENAME}|g" \
    -e "s|{{DOMAIN}}|${CLIP_DOMAIN}|g" \
    -e "s|{{URL}}|${URL}|g" \
    "$CLIP_TEMPLATE" > "$TMPHTML"

# Upload clip and page to server
ssh "$CLIP_SERVER" "mkdir -p '${CLIP_DIR}/${SLUG}'"
scp -q "$CLIP_FILE" "${CLIP_SERVER}:${CLIP_DIR}/${SLUG}/${FILENAME}"
scp -q "$TMPHTML" "${CLIP_SERVER}:${CLIP_DIR}/${SLUG}/index.html"
rm -f "$TMPHTML"
# Stamp ownership
ssh "$CLIP_SERVER" "printf '%s' '${IDENT}' > '${CLIP_DIR}/${SLUG}/.owner'"

ssh "$CLIP_SERVER" "chmod 644 '${CLIP_DIR}/${SLUG}'/*"

# Generate thumbnail on server (first frame)
ssh "$CLIP_SERVER" "ffmpeg -y -i '${CLIP_DIR}/${SLUG}/${FILENAME}' -vframes 1 -q:v 2 '${CLIP_DIR}/${SLUG}/thumb.jpg' 2>/dev/null"

# Copy link to clipboard
printf '%s' "$URL" | xclip -selection clipboard

# Notify
$NOTIFY_CMD "Clip uploaded" "$URL"
